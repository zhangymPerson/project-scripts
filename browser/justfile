set unstable := true

# 默认任务：使用 fzf 选择要执行的任务
default: format
    just --fmt
    just --list

run:
    @just --choose 

# Edge playwright 用户数据目录

export EDGE_PLAYWRIGHT_USER_DATA_DIR := "/tmp/edge-playwright-data"

# mac 启动 Microsoft Edge 浏览器（Playwright 调试模式）
mac-start-edge:
    #!/usr/bin/env bash
    echo "启动 Microsoft Edge 浏览器（Playwright 调试模式）..."
    mkdir -p "$EDGE_PLAYWRIGHT_USER_DATA_DIR"
    '/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge' \
        --remote-debugging-port=9222 \
        --user-data-dir="$EDGE_PLAYWRIGHT_USER_DATA_DIR" \
        --no-first-run \
        --no-default-browser-check \
        --disable-features=RendererCodeIntegrity \
        'about:blank' >/dev/null 2>&1 &
    echo "浏览器已启动，调试端口: 9222"
    echo "用户数据目录: $EDGE_PLAYWRIGHT_USER_DATA_DIR"

baidu:
    uv run browser_example_baidu.py

format:
    just --fmt
    uvx ruff check --fix .
