# =============================================================================
# 应用配置
# =============================================================================
APP_NAME=myapp
APP_ENV=dev                    # 环境: dev/test/prod
APP_VERSION=1.0.0
DEBUG=false

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=INFO
LOG_DIR=../logs

# =============================================================================
# 数据库配置 (MySQL)
# =============================================================================
# 开发环境（单实例）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=dev_user
MYSQL_PASSWORD=dev_pass
MYSQL_DATABASE=dev_db

# 生产环境（多实例，可覆盖）
# ENV_MYSQL_HOST_MASTER=mysql-master.example.com
# ENV_MYSQL_HOST_SLAVE_1=mysql-slave-1.example.com
# ENV_MYSQL_HOST_SLAVE_2=mysql-slave-2.example.com

# =============================================================================
# Redis 配置
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # 生产环境使用

# =============================================================================
# Kafka 配置
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=myapp-dev

# =============================================================================
# S3 对象存储
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=myapp-dev-bucket
S3_ENDPOINT_URL=http://localhost:9000  # MinIO 本地开发

# =============================================================================
# API 配置
# =============================================================================
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# 数据库连接池
# =============================================================================
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_TIMEOUT=30
